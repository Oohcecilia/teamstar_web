{
  "name": "Task",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "title": "Title"
    },
    "description": {
      "type": "string",
      "title": "Description"
    },
    "status": {
      "type": "string",
      "title": "Status",
      "enum": [
        "upcoming",
        "today",
        "previous",
        "completed"
      ],
      "default": "upcoming"
    },
    "priority": {
      "type": "string",
      "title": "Priority",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "default": "medium"
    },
    "due_date": {
      "type": "string",
      "format": "date-time",
      "title": "Due Date"
    },
    "assigned_to": {
      "type": "array",
      "title": "Assigned Members",
      "items": {
        "type": "string"
      }
    },
    "team_id": {
      "type": "string",
      "title": "Team ID"
    },
    "organization_id": {
      "type": "string",
      "title": "Organization ID"
    },
    "location_name": {
      "type": "string",
      "title": "Location Name"
    },
    "latitude": {
      "type": "number",
      "title": "Latitude"
    },
    "longitude": {
      "type": "number",
      "title": "Longitude"
    },
    "order": {
      "type": "number",
      "title": "Order",
      "default": 0
    }
  },
  "required": [
    "title",
    "status"
  ]
}